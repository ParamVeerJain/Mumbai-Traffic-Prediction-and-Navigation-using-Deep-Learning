          "text": [
            "Loaded predictions parquet: 12/12 files\n",
            "  matrix shape=(9065, 168, 1)\n",
            "Loading raw TTR + cong (vectorized) ...\n",
            "  raw_ttr     1.000/1.331/10.000\n",
