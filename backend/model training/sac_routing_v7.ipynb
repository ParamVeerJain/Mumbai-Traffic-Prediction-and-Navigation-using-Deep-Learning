        "print(f'N_EPOCHS={N_EPOCHS} | N_EPISODES_PER_EPOCH={N_EPISODES_PER_EPOCH} | N_AGENTS={N_AGENTS}')\n",
        "print(f'Total agent-episodes: {N_EPOCHS * N_EPISODES_PER_EPOCH * N_AGENTS:,}')\n"
      ]
